{
  "schema_version": "OIDC_SERVICE_ACCESS_V1",
  "client_id": "nursing-station",
  "subject": "service:nursing-station",
  "tenant_claim_required": true,
  "access_paths": [
    {
      "resource_server": "bullettrain-api-gateway",
      "audience": "bullettrain",
      "mode": "oidc-bearer",
      "base_url_env": "NURSING_STATION_BULLETTRAIN_API_GATEWAY_URL",
      "token_env": "NURSING_STATION_BULLETTRAIN_API_GATEWAY_TOKEN",
      "tenant_env": "NURSING_STATION_BULLETTRAIN_TENANT_ID",
      "required_claims": [
        "exp",
        "iat",
        "iss",
        "aud",
        "sub",
        "tenant_id",
        "scope"
      ],
      "required_scopes": [
        "nursing:read",
        "nursing:write",
        "patient:read",
        "audit:write"
      ],
      "denied_scopes": [
        "system:admin"
      ]
    }
  ]
}