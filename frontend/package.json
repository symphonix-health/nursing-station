    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.19.0",
    "openapi-typescript": "^7.13.0",
    "typescript": "~5.7.2",
    "vite": "^6.1.0"
  }
